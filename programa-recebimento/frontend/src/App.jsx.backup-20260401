          qtdNFe: info.qtdTotal,
          qtdNFeOriginal: info.qtdTotal,
          totalRecebido: info.qtdTotal,
          faltando: -info.qtdTotal,
          percentual: 0,
          diferenca: info.qtdTotal,
          status: 'a_mais',
          noPedido: false,
          noNFe: true,
          associacaoManual: false,
          detalhesNFes: info.nfes
