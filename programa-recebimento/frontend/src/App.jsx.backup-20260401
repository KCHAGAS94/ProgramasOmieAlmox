  // Comparação pedido x NFes (agregação)
  const comparacao = useMemo(() => {
    if (!pedidoData?.produtos_consulta) {
      return null;
    }

    const produtosPedido = pedidoData.produtos_consulta || [];
    const resultado = [];
    const nfeUsados = new Set();

    const qtdPorCodigo = new Map();

    nfes.forEach(nfe => {
      nfe.itens.forEach(itemNFe => {
        const codigo = itemNFe.codigo;
        if (!qtdPorCodigo.has(codigo)) {
          qtdPorCodigo.set(codigo, {
            qtdTotal: 0,
            nfes: [],
            descricao: itemNFe.descricao,
            unidade: itemNFe.unidade
          });
        }
        const info = qtdPorCodigo.get(codigo);
        info.qtdTotal += parseFloat(itemNFe.quantidade || 0);
        info.nfes.push({
          numero_nfe: nfe.numero_nfe,
          qtd: parseFloat(itemNFe.quantidade || 0),
          codigo_nfe: itemNFe.codigo
        });
      });
    });

    produtosPedido.forEach(itemPedido => {
      const codigoPedido = itemPedido.cProduto;
      const qtdPedido = parseFloat(itemPedido.nQtde || 0);
      const qtdRecebida = parseFloat(itemPedido.nQtdeRec || 0);

      const codigosAssociados = associacoes[codigoPedido];
      let infoNFe = null;
      let temAssociacaoManual = false;

      if (codigosAssociados) {
        if (Array.isArray(codigosAssociados) && codigosAssociados.length > 0) {
          temAssociacaoManual = true;
          const nfesAgregadas = [];
          let qtdTotalAgregada = 0;
          let descricaoAgregada = '';
          let unidadeAgregada = '';

          codigosAssociados.forEach(codigoAssoc => {
            const infoAssoc = qtdPorCodigo.get(codigoAssoc);
            if (infoAssoc) {
              qtdTotalAgregada += infoAssoc.qtdTotal;
              nfesAgregadas.push(...infoAssoc.nfes);
              if (!descricaoAgregada) descricaoAgregada = infoAssoc.descricao;
              if (!unidadeAgregada) unidadeAgregada = infoAssoc.unidade;
            }
          });

          if (qtdTotalAgregada > 0) {
            infoNFe = {
              qtdTotal: qtdTotalAgregada,
              nfes: nfesAgregadas,
              descricao: descricaoAgregada,
              unidade: unidadeAgregada
            };
          }
        } else {
          temAssociacaoManual = true;
          infoNFe = qtdPorCodigo.get(codigosAssociados);
        }
      } else {
        infoNFe = qtdPorCodigo.get(codigoPedido);

        if (!infoNFe) {
          for (const [codigoNFe, info] of qtdPorCodigo.entries()) {
            if (codigosSaoSimilares(codigoPedido, codigoNFe)) {
              infoNFe = info;
              break;
            }
          }
        }
      }

      const qtdNFeOriginal = infoNFe ? infoNFe.qtdTotal : 0;
      let qtdNFe = qtdNFeOriginal;
      let temDivergenciaUnidade = false;
      let fatorConversao = null;
      const unidadePedido = itemPedido.cUnidade;
      const unidadeNFe = infoNFe?.unidade;

      if (infoNFe && unidadePedido && unidadeNFe && unidadePedido !== unidadeNFe) {
        temDivergenciaUnidade = true;
        fatorConversao = obterFatorConversao(codigoPedido, unidadePedido, unidadeNFe);

        if (fatorConversao) {
          qtdNFe = qtdNFeOriginal * fatorConversao;
        }
      }

      const totalRecebido = qtdRecebida + qtdNFe;
      const faltando = qtdPedido - totalRecebido;
      const percentual = qtdPedido > 0 ? (totalRecebido / qtdPedido) * 100 : 0;

      let status = 'faltando';
      if (totalRecebido >= qtdPedido - 0.01) {
        if (totalRecebido <= qtdPedido + 0.01) {
          status = 'confere';
        } else {
          status = 'excesso';
        }
      } else if (totalRecebido > 0) {
        status = 'parcial';
      }

      if (infoNFe) {
        infoNFe.nfes.forEach(n => nfeUsados.add(n.codigo_nfe));
      }

      resultado.push({
        codigo: codigoPedido,
        codigoNFe: infoNFe?.nfes[0]?.codigo_nfe || null,
        descricao: itemPedido.cDescricao,
        descricaoNFe: infoNFe?.descricao,
        unidade: itemPedido.cUnidade,
        unidadeNFe: infoNFe?.unidade,
        qtdPedido,
        qtdRecebida,
        qtdNFeOriginal,
        qtdNFe,
        totalRecebido,
        faltando,
        percentual,
        diferenca: totalRecebido - qtdPedido,
        status,
        noPedido: true,
        noNFe: !!infoNFe,
        associacaoManual: temAssociacaoManual,
        codigosAssociados: codigosAssociados || null,
        detalhesNFes: infoNFe?.nfes || [],
        temDivergenciaUnidade,
        fatorConversao,
        precisaConfigurarConversao: temDivergenciaUnidade
      });
    });

    qtdPorCodigo.forEach((info, codigo) => {
      if (!nfeUsados.has(codigo)) {
        resultado.push({
          codigo: null,
          codigoNFe: codigo,
          descricao: null,
