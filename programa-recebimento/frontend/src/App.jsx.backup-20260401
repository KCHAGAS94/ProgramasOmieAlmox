const API_BASE = `http://${window.location.hostname}:4002/api`;

// Função para decodificar entidades HTML
function decodeHtmlEntities(text) {
  if (!text) return text;
  return text
    .replace(/&apos;/g, "'")
    .replace(/&quot;/g, '"')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&amp;/g, '&');
}

// Função para verificar se dois códigos são similares
function codigosSaoSimilares(codigo1, codigo2) {
  if (!codigo1 || !codigo2) return false;
  if (codigo1 === codigo2) return true;

  const prefixo1 = codigo1.slice(0, -1);
  const prefixo2 = codigo2.slice(0, -1);

  if (prefixo1 === prefixo2 && prefixo1.length > 0) {
    return true;
  }

  const diff = Math.abs(codigo1.length - codigo2.length);
  if (diff === 1) {
    const maior = codigo1.length > codigo2.length ? codigo1 : codigo2;
    const menor = codigo1.length > codigo2.length ? codigo2 : codigo1;

    if (maior.slice(0, -1) === menor) {
      return true;
    }

    if (maior.length > 2 && menor.length > 1) {
      if (maior.slice(0, -2) === menor.slice(0, -1)) {
        return true;
      }
    }
  }

  if (codigo1.length > 2 && codigo2.length > 2) {
    const prefixo1_2 = codigo1.slice(0, -2);
    const prefixo2_2 = codigo2.slice(0, -2);

    if (prefixo1_2 === prefixo2_2 && prefixo1_2.length > 0) {
      return true;
    }
  }

  return false;
}

function App() {
  const [autenticado, setAutenticado] = useState(false);
  const [usuarioLogado, setUsuarioLogado] = useState(null);
  const [numeroPedido, setNumeroPedido] = useState('');
  const [linkAtual, setLinkAtual] = useState('');
  const [pedidoData, setPedidoData] = useState(null);
  const [nfes, setNfes] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const [success, setSuccess] = useState('');
  const [associacoes, setAssociacoes] = useState({});
  const [associandoItem, setAssociandoItem] = useState(null);
  const [debugData, setDebugData] = useState(null);
  const [adicionandoNFe, setAdicionandoNFe] = useState(false);
  const [conversoes, setConversoes] = useState({});
  const [configurandoConversao, setConfigurandoConversao] = useState(null);
  const [conferencias, setConferencias] = useState({});
  const [associacoesManuais, setAssociacoesManuais] = useState({});
  const [codigosNumericos, setCodigosNumericos] = useState({});
  const [modalContagemAberto, setModalContagemAberto] = useState(false);
  const [itemSelecionadoIdx, setItemSelecionadoIdx] = useState(null);
  const [infoModal, setInfoModal] = useState(null);
  const [novaQuantidadeContagem, setNovaQuantidadeContagem] = useState('');
  const [dadosConferencia, setDadosConferencia] = useState({});

  // Estado para modal DANFE (visualização formatada do XML)
  const [modalDanfe, setModalDanfe] = useState(null); // null ou { dados, loading }
  const [loadingDanfe, setLoadingDanfe] = useState(false);

  // Origem dos dados do pedido (cache ou api)
  const [origemPedido, setOrigemPedido] = useState(null);
  const [pedidoSalvoEm, setPedidoSalvoEm] = useState(null);

  // Estados para lista de pedidos
  const [telaAtual, setTelaAtual] = useState('lista');
  const [listaPedidos, setListaPedidos] = useState([]);
  const [filtroStatus, setFiltroStatus] = useState('todos');
  const [buscaPedido, setBuscaPedido] = useState('');

  // Sub-aba dentro da tela de conferência
  const [abaDetalhes, setAbaDetalhes] = useState('recebimento');

  // Dark mode
  const [darkMode, setDarkMode] = useState(() => {
    if (typeof window !== 'undefined') {
      return localStorage.getItem('darkMode') === 'true';
    }
    return false;
  });

  useEffect(() => {
    if (darkMode) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    localStorage.setItem('darkMode', darkMode);
  }, [darkMode]);

  // Verifica autenticação ao carregar
  useEffect(() => {
    const urlParams = new URLSearchParams(window.location.search);
    const tokenUrl = urlParams.get('token');
    const usuarioUrl = urlParams.get('usuario');

    if (tokenUrl && usuarioUrl) {
      localStorage.setItem('token', tokenUrl);
      localStorage.setItem('usuario', usuarioUrl);
      window.history.replaceState({}, document.title, window.location.pathname);
    }

    const token = localStorage.getItem('token');
    const usuarioStr = localStorage.getItem('usuario');

    if (token && usuarioStr) {
      try {
        const usuario = JSON.parse(usuarioStr);
        setUsuarioLogado(usuario);
        setAutenticado(true);
      } catch (e) {
        console.error('Erro ao parsear usuário:', e);
        setAutenticado(false);
      }
    }
  }, []);

  const buscarDados = async (numPedidoParam = null, forcarAtualizacao = false) => {
    const numPedido = numPedidoParam || numeroPedido;

    if (!numPedido || !numPedido.trim()) {
      setError('Digite o número do pedido');
      return;
    }

    setLoading(true);
    setError('');
    setSuccess('');
    setPedidoData(null);
    setNfes([]);
    setAssociacoes({});
    setCodigosNumericos({});
    setOrigemPedido(null);
    setPedidoSalvoEm(null);

    try {
      const pedidoResponse = await axios.post(`${API_BASE}/consultar-pedido`, {
        numero_pedido: numPedido.trim(),
        forcar_atualizacao: forcarAtualizacao
      });

      if (pedidoResponse.data.success) {
        setPedidoData(pedidoResponse.data.pedido);
        setOrigemPedido(pedidoResponse.data.origem || 'api');
        setPedidoSalvoEm(pedidoResponse.data.salvo_em || null);

        const pedido = pedidoResponse.data.pedido;
        if (pedido && pedido.produtos_consulta) {
          const mapeamento = {};
          pedido.produtos_consulta.forEach(produto => {
            if (produto.cProduto && produto.nCodProd) {
              mapeamento[produto.cProduto] = produto.nCodProd;
            }
          });
          setCodigosNumericos(mapeamento);
          console.log('[CODIGOS] Mapeamento criado:', Object.keys(mapeamento).length, 'produtos');
        }
      }

      try {
        const buscarPedidoResponse = await axios.post(`${API_BASE}/buscar-por-pedido`, {
          numero_pedido: numPedido.trim()
        });

        if (buscarPedidoResponse.data.success && buscarPedidoResponse.data.encontrado) {
          const nfesSalvas = buscarPedidoResponse.data.nfes || [];

          if (nfesSalvas.length > 0) {
            console.log(`Encontradas ${nfesSalvas.length} NFe(s) salva(s)`);

            const nfesProcessadas = [];
            for (const nfeSalva of nfesSalvas) {
              try {
                const xmlResponse = await axios.post(`${API_BASE}/baixar-xml`, {
                  link: nfeSalva.link_xml
                });

                if (xmlResponse.data.success) {
                  nfesProcessadas.push({
                    numero_nfe: nfeSalva.numero_nfe,
                    link_xml: nfeSalva.link_xml,
                    itens: xmlResponse.data.itens,
                    data_processamento: nfeSalva.data_processamento,
                    associacoes: nfeSalva.associacoes || {}
                  });
                }
              } catch (xmlErr) {
                console.error(`Erro ao baixar XML da NFe ${nfeSalva.numero_nfe}:`, xmlErr.message);
              }
            }

            setNfes(nfesProcessadas);

            const todasAssociacoes = {};
            nfesProcessadas.forEach(nfe => {
              Object.entries(nfe.associacoes || {}).forEach(([codigoPedido, codigoNFe]) => {
                if (!todasAssociacoes[codigoPedido]) {
                  todasAssociacoes[codigoPedido] = [];
                }
                if (!todasAssociacoes[codigoPedido].includes(codigoNFe)) {
                  todasAssociacoes[codigoPedido].push(codigoNFe);
                }
              });
            });
            setAssociacoes(todasAssociacoes);

            for (const nfe of nfesProcessadas) {
              await carregarContagensDetalhadas(numPedido.trim(), nfe.numero_nfe);
            }

            setSuccess(`Carregadas ${nfesProcessadas.length} NFe(s) do pedido!`);
          } else {
            setSuccess('Pedido carregado. Use o botão "Adicionar NFe" para processar uma nota fiscal.');
          }
        } else {
          setSuccess('Pedido carregado. Use o botão "Adicionar NFe" para processar uma nota fiscal.');
        }
      } catch (buscarErr) {
        console.warn('Erro ao buscar NFes salvas:', buscarErr.message);
        setSuccess('Pedido carregado. Use o botão "Adicionar NFe" para processar uma nota fiscal.');
      }

      setDebugData({
        api_url: 'https://app.omie.com.br/api/v1/produtos/pedidocompra/',
        api_call: 'ConsultarPedCompra',
        pedido_completo: pedidoResponse.data.pedido
      });
    } catch (err) {
      setError(err.response?.data?.error || err.message || 'Erro ao buscar dados');
    } finally {
      setLoading(false);
    }
  };

  const adicionarNovaFe = async () => {
    if (!linkAtual.trim()) {
      setError('Digite o link do XML da NFe');
      return;
    }

    if (!linkAtual.startsWith('http')) {
      setError('Link inválido. Deve começar com http:// ou https://');
      return;
    }

    if (!pedidoData) {
      setError('Carregue o pedido primeiro');
      return;
    }

    setLoading(true);
    setError('');
    setSuccess('');

    try {
      const xmlResponse = await axios.post(`${API_BASE}/baixar-xml`, {
        link: linkAtual.trim()
      });

      if (xmlResponse.data.success) {
        const novaFe = {
          numero_nfe: xmlResponse.data.itens[0]?.numeroNF || 'N/A',
          link_xml: linkAtual.trim(),
          itens: xmlResponse.data.itens,
          data_processamento: new Date().toISOString(),
          associacoes: {}
        };

        const jaExiste = nfes.some(nfe => nfe.numero_nfe === novaFe.numero_nfe);
        if (jaExiste) {
          setError(`NFe ${novaFe.numero_nfe} já foi processada para este pedido`);
          setLoading(false);
          return;
        }

        const nfesAtualizadas = [...nfes, novaFe];
        setNfes(nfesAtualizadas);

        await axios.post(`${API_BASE}/salvar-associacoes`, {
          numero_pedido: numeroPedido,
          numero_nfe: novaFe.numero_nfe,
          associacoes: novaFe.associacoes,
          link_xml: novaFe.link_xml
        });

        await carregarContagensDetalhadas(numeroPedido, novaFe.numero_nfe);

        setSuccess(`NFe ${novaFe.numero_nfe} adicionada com sucesso!`);
        setLinkAtual('');
        setAdicionandoNFe(false);
      }
    } catch (err) {
      setError(err.response?.data?.error || err.message || 'Erro ao processar NFe');
    } finally {
      setLoading(false);
    }
  };

  const associarItem = async (codigoPedido, codigoNFe, numeroNFe) => {
    console.log(`[ASSOCIAR] ${codigoPedido} -> ${codigoNFe} (NFe: ${numeroNFe})`);

    const associacoesAtuais = associacoes[codigoPedido] || [];
    const novasAssociacoes = {
      ...associacoes,
      [codigoPedido]: [...associacoesAtuais, codigoNFe]
    };

    setAssociacoes(novasAssociacoes);
    setAssociandoItem(null);

    const nfesAtualizadas = nfes.map(nfe => {
      if (nfe.numero_nfe === numeroNFe) {
        return {
          ...nfe,
          associacoes: {
            ...nfe.associacoes,
            [codigoPedido]: codigoNFe
          }
        };
      }
      return nfe;
    });

    setNfes(nfesAtualizadas);

    try {
      const nfeAtualizada = nfesAtualizadas.find(n => n.numero_nfe === numeroNFe);
      await axios.post(`${API_BASE}/salvar-associacoes`, {
        numero_pedido: numeroPedido,
        numero_nfe: numeroNFe,
        associacoes: nfeAtualizada.associacoes,
        link_xml: nfeAtualizada.link_xml
      });

      const chave = `${numeroPedido}_${codigoPedido}`;
      const assocAtuais = associacoesManuais[chave] || [];
      setAssociacoesManuais(prev => ({
        ...prev,
        [chave]: Array.isArray(assocAtuais) ? [...assocAtuais, codigoNFe] : [codigoNFe]
      }));

      console.log(`Associação ${novasAssociacoes[codigoPedido].length} adicionada para ${codigoPedido}`);
      setSuccess(`Associação adicionada! Total: ${novasAssociacoes[codigoPedido].length} item(ns)`);
    } catch (error) {
      console.error('Erro ao salvar associação:', error.message);
      setError('Associação criada localmente, mas não foi possível salvar no banco');
    }
  };

  const removerAssociacao = async (codigoPedido, codigoNFeEspecifico = null) => {
    console.log(`[REMOVER] ${codigoPedido}${codigoNFeEspecifico ? ` -> ${codigoNFeEspecifico}` : ' (todas)'}`);

    const associacoesAtuais = associacoes[codigoPedido];
    let novasAssociacoes = { ...associacoes };

    if (codigoNFeEspecifico && Array.isArray(associacoesAtuais)) {
      const arrayAtualizado = associacoesAtuais.filter(cod => cod !== codigoNFeEspecifico);
      if (arrayAtualizado.length > 0) {
        novasAssociacoes[codigoPedido] = arrayAtualizado;
      } else {
        delete novasAssociacoes[codigoPedido];
      }
    } else {
      delete novasAssociacoes[codigoPedido];
    }

    setAssociacoes(novasAssociacoes);

    const nfesAtualizadas = nfes.map(nfe => {
      const novasAssociacoesNFe = { ...nfe.associacoes };

      if (codigoNFeEspecifico) {
        if (novasAssociacoesNFe[codigoPedido] === codigoNFeEspecifico) {
          delete novasAssociacoesNFe[codigoPedido];
        }
      } else {
        delete novasAssociacoesNFe[codigoPedido];
      }

      return {
        ...nfe,
        associacoes: novasAssociacoesNFe
      };
    });

    setNfes(nfesAtualizadas);

    try {
      for (const nfe of nfesAtualizadas) {
        await axios.post(`${API_BASE}/salvar-associacoes`, {
          numero_pedido: numeroPedido,
          numero_nfe: nfe.numero_nfe,
          associacoes: nfe.associacoes,
          link_xml: nfe.link_xml
        });
      }

      const chave = `${numeroPedido}_${codigoPedido}`;
      const assocAtuais = associacoesManuais[chave];

      if (codigoNFeEspecifico) {
        await axios.post(`${API_BASE}/remover-associacao-manual`, {
          numero_pedido: numeroPedido,
          codigo_pedido: codigoPedido,
          codigo_nfe: codigoNFeEspecifico
        });

        const arrayAtualizado = Array.isArray(assocAtuais) ? assocAtuais.filter(cod => cod !== codigoNFeEspecifico) : [];
        setAssociacoesManuais(prev => {
          if (arrayAtualizado.length > 0) {
            return { ...prev, [chave]: arrayAtualizado };
          } else {
            const novo = { ...prev };
            delete novo[chave];
            return novo;
          }
        });
      } else {
        await axios.post(`${API_BASE}/remover-associacao-manual`, {
          numero_pedido: numeroPedido,
          codigo_pedido: codigoPedido
        });

        setAssociacoesManuais(prev => {
          const novo = { ...prev };
          delete novo[chave];
          return novo;
        });
      }

      const qtdRestante = novasAssociacoes[codigoPedido]?.length || 0;
      console.log(`Associação removida (restantes: ${qtdRestante})`);
      setSuccess(`Associação removida! ${qtdRestante > 0 ? `Restam ${qtdRestante}` : 'Nenhuma restante'}`);
    } catch (error) {
      console.error('Erro ao salvar após remover:', error.message);
      setError('Associação removida localmente, mas não foi possível salvar no banco');
    }
  };

  const excluirNFe = async (numeroNFe) => {
    console.log('[EXCLUSAO] Iniciando exclusão da NFe:', numeroNFe);
    console.log('[EXCLUSAO] Usuário logado:', usuarioLogado);
    console.log('[EXCLUSAO] Pedido atual:', numeroPedido);

    if (!usuarioLogado) {
      const msg = 'Usuário não está logado. Recarregue a página.';
      console.error('[EXCLUSAO] ' + msg);
      setError(msg);
      return;
    }

    if (usuarioLogado.tipo !== 'admin') {
      const msg = `Apenas administradores podem excluir NFes. Seu tipo: ${usuarioLogado.tipo}`;
      console.error('[EXCLUSAO] ' + msg);
      setError(msg);
      return;
    }

    if (!numeroPedido) {
      const msg = 'Número do pedido não está definido';
      console.error('[EXCLUSAO] ' + msg);
      setError(msg);
      return;
    }

    if (!confirm(`Tem certeza que deseja excluir a NFe ${numeroNFe}?\n\nEsta ação não pode ser desfeita!`)) {
      console.log('[EXCLUSAO] Cancelado pelo usuário');
      return;
    }

    setLoading(true);
    setError('');
    setSuccess('');

    try {
      console.log('[EXCLUSAO] Enviando requisição para:', `${API_BASE}/excluir-nfe`);
      console.log('[EXCLUSAO] Dados:', { numero_pedido: numeroPedido, numero_nfe: numeroNFe });

      const response = await axios.post(`${API_BASE}/excluir-nfe`, {
        numero_pedido: numeroPedido,
        numero_nfe: numeroNFe
      });

      console.log('[EXCLUSAO] Resposta recebida:', response.data);

      if (response.data.success) {
        const nfesAtualizadas = nfes.filter(nfe => nfe.numero_nfe !== numeroNFe);
        setNfes(nfesAtualizadas);

        const novasAssociacoes = { ...associacoes };
        Object.keys(novasAssociacoes).forEach(key => {
          const nfeAssociada = nfes.find(nfe => nfe.numero_nfe === numeroNFe);
          if (nfeAssociada?.associacoes[key]) {
            delete novasAssociacoes[key];
          }
        });
        setAssociacoes(novasAssociacoes);

        setSuccess(`NFe ${numeroNFe} excluída com sucesso`);
      }
    } catch (error) {
      console.error('[EXCLUSAO] Erro completo:', error);
      const errorMsg = error.response?.data?.error || error.message || 'Erro ao excluir NFe';
      setError(errorMsg);
    } finally {
      setLoading(false);
    }
  };

  const carregarConversoes = async () => {
    try {
      console.log('[CONVERSOES] Carregando conversões do backend...');
      const response = await axios.get(`${API_BASE}/listar-conversoes`);
      if (response.data.success) {
        const conversoesCarregadas = response.data.conversoes || {};
        setConversoes(conversoesCarregadas);
        console.log('[CONVERSOES] Carregadas:', Object.keys(conversoesCarregadas).length, 'produtos');
      }
    } catch (error) {
      console.error('[CONVERSOES] Erro ao carregar:', error.message);
    }
  };

  const salvarConversao = async (codigoProduto, unidadePedido, unidadeNFe, fator) => {
    console.log('[SALVAR CONVERSAO] Iniciando salvamento...');
    console.log('[SALVAR CONVERSAO] Parâmetros:', { codigoProduto, unidadePedido, unidadeNFe, fator });
    try {
      const payload = {
        codigo_produto: codigoProduto,
        unidade_pedido: unidadePedido,
        unidade_nfe: unidadeNFe,
        fator: parseFloat(fator)
      };

      const response = await axios.post(`${API_BASE}/salvar-conversao`, payload);

      if (response.data.success) {
        await carregarConversoes();
        setSuccess(`Conversão salva: 1 ${unidadeNFe} = ${fator} ${unidadePedido}`);
        setConfigurandoConversao(null);
        console.log('[CONVERSOES] Salva com sucesso');
      }
    } catch (error) {
      console.error('[CONVERSOES] Erro ao salvar:', error);
      setError(error.response?.data?.error || 'Erro ao salvar conversão');
    }
  };

  const obterFatorConversao = (codigoProduto, unidadePedido, unidadeNFe) => {
    if (!conversoes[codigoProduto]) {
      return null;
    }

    const chave = `${unidadePedido}_${unidadeNFe}`;
    const fator = conversoes[codigoProduto][chave]?.fator || null;
    return fator;
  };

  const carregarConferencias = async () => {
    if (!numeroPedido) return;

    try {
      const response = await axios.get(`${API_BASE}/listar-conferencias`);
      if (response.data.success) {
        const conferenciasCarregadas = response.data.conferencias || [];

        const conferenciasMap = {};
        conferenciasCarregadas.forEach(conf => {
          conf.itens?.forEach(item => {
            const chave = `${conf.numero_pedido}_${conf.numero_nfe}_${item.codigo_nfe}`;
            conferenciasMap[chave] = item.quantidade_fisica;
          });
        });

        setConferencias(conferenciasMap);
      }
    } catch (error) {
      console.error('[CONFERENCIAS] Erro ao carregar:', error.message);
    }
  };

  const salvarConferenciaFisica = async (numeroNFe, codigoNFe, quantidadeNFe, quantidadeFisica) => {
    try {
      const response = await axios.post(`${API_BASE}/salvar-conferencia`, {
        numero_pedido: numeroPedido,
        numero_nfe: numeroNFe,
        codigo_nfe: codigoNFe,
        quantidade_nfe: quantidadeNFe,
        quantidade_fisica: parseFloat(quantidadeFisica),
        conferido_por: usuarioLogado
      });

      if (response.data.success) {
        await carregarConferencias();
        setSuccess(`Conferência salva: ${quantidadeFisica} unidades contadas`);
      }
    } catch (error) {
      console.error('[CONFERENCIAS] Erro ao salvar:', error.message);
      setError(error.response?.data?.error || 'Erro ao salvar conferência');
    }
  };

  const abrirModalContagem = (chave, codigo, descricao, qtdEsperada, unidade, codigoPedido = null, descricaoPedido = null) => {
    setItemSelecionadoIdx(chave);
    setInfoModal({
      codigo,
      descricao,
      qtdEsperada,
      unidade,
      codigoPedido,
      descricaoPedido
    });
    setModalContagemAberto(true);
    setNovaQuantidadeContagem('');
  };

  const fecharModalContagem = async () => {
    if (itemSelecionadoIdx && dadosConferencia[itemSelecionadoIdx]) {
      const total = dadosConferencia[itemSelecionadoIdx].totalContado;
      const [numeroPed, numeroNFe, codigoNFe] = itemSelecionadoIdx.split('_');

      await salvarConferenciaFisica(numeroNFe, codigoNFe, 0, total);
      await salvarContagensDetalhadas();
    }
    setModalContagemAberto(false);
    setItemSelecionadoIdx(null);
    setInfoModal(null);
